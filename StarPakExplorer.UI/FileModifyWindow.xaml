<Window x:Class="StarPakExplorer.UI.FileModifyWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="clr-namespace:StarPakExplorer.UI"
        Title="修改资源"
        Width="980"
        Height="760"
        MinWidth="860"
        MinHeight="640"
        WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />
    </Window.Resources>
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Padding="12"
                Background="#F4F7FB"
                CornerRadius="8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="{Binding Title}" FontSize="18" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding FileTypeText}" Foreground="#43546A" Margin="0,4,0,0" />
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="保存" Width="80" Margin="0,0,8,0" Command="{Binding SaveCommand}" />
                    <Button Content="关闭" Width="80" Command="{Binding CloseCommand}" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="0,10,0,10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Margin="0,0,0,8"
                    Padding="10,6"
                    Background="#F7F7F7"
                    BorderBrush="#E3E3E3"
                    BorderThickness="1"
                    CornerRadius="6"
                    Visibility="{Binding CanEditText, Converter={StaticResource BoolToVisibility}}">
                <DockPanel>
                    <TextBlock Text="{Binding ModeHintText}"
                               VerticalAlignment="Center"
                               Foreground="#43546A"
                               Margin="0,0,12,0" />
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                        <RadioButton Content="源数据"
                                     GroupName="ModifyMode"
                                     IsChecked="{Binding IsSourceMode, Mode=TwoWay}"
                                     Margin="0,0,8,0" />
                        <RadioButton Content="阅读模式"
                                     GroupName="ModifyMode"
                                     IsChecked="{Binding IsReadingMode, Mode=TwoWay}"
                                     Margin="0,0,12,0" />
                        <TextBlock Text="编码:"
                                   VerticalAlignment="Center"
                                   Margin="0,0,6,0" />
                        <ComboBox Width="140"
                                  ItemsSource="{Binding EncodingOptions}"
                                  DisplayMemberPath="Name"
                                  SelectedValuePath="Name"
                                  SelectedValue="{Binding SelectedEncodingName}" />
                    </StackPanel>
                </DockPanel>
            </Border>

            <Grid Grid.Row="1">
                <StackPanel Visibility="{Binding CanEditText, Converter={StaticResource BoolToVisibility}}">
                    <TextBox Text="{Binding EditableText, UpdateSourceTrigger=PropertyChanged}"
                             FontFamily="Consolas"
                             FontSize="13"
                             AcceptsReturn="True"
                             AcceptsTab="True"
                             TextWrapping="NoWrap"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto"
                             IsReadOnly="{Binding IsReadingMode}" 
                             Visibility="{Binding IsSourceMode, Converter={StaticResource BoolToVisibility}}" />

                    <RichTextBox ui:RichTextBoxBindings.BoundDocument="{Binding PreviewDocument}"
                                 FontFamily="Consolas"
                                 FontSize="13"
                                 IsReadOnly="True"
                                 IsDocumentEnabled="True"
                                 BorderThickness="1"
                                 BorderBrush="#DDE2EA"
                                 Background="White"
                                 VerticalScrollBarVisibility="Auto"
                                 HorizontalScrollBarVisibility="Auto"
                                 Visibility="{Binding IsReadingMode, Converter={StaticResource BoolToVisibility}}" />
                </StackPanel>

                <StackPanel Visibility="{Binding CanReplaceBinary, Converter={StaticResource BoolToVisibility}}">
                    <Border Padding="12"
                            Background="#FAFAFA"
                            BorderBrush="#E3E3E3"
                            BorderThickness="1"
                            CornerRadius="6">
                        <StackPanel>
                            <TextBlock Text="{Binding StatusMessage}" Foreground="#43546A" Margin="0,0,0,8" TextWrapping="Wrap" />
                            <Button Content="选择替换文件" Width="120" Command="{Binding SelectReplacementCommand}" />
                            <TextBlock Text="{Binding ReplacementPath}" Margin="0,8,0,0" TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </Border>

                    <Border Margin="0,10,0,0"
                            Padding="12"
                            Background="#FFFFFF"
                            BorderBrush="#E3E3E3"
                            BorderThickness="1"
                            CornerRadius="6">
                        <StackPanel>
                            <TextBlock Text="预览" FontWeight="SemiBold" Margin="0,0,0,8" />
                            <Image Source="{Binding PreviewImageSource}"
                                   Stretch="Uniform"
                                   MaxHeight="520"
                                   Visibility="{Binding IsImageFile, Converter={StaticResource BoolToVisibility}}" />
                            <TextBlock Text="{Binding StatusMessage}"
                                       TextWrapping="Wrap"
                                       Visibility="{Binding IsAudioFile, Converter={StaticResource BoolToVisibility}}" />
                        </StackPanel>
                    </Border>
                </StackPanel>

                <Border Background="#FAFAFA"
                        BorderBrush="#E3E3E3"
                        BorderThickness="1"
                        Padding="16"
                        CornerRadius="6"
                        Visibility="{Binding IsOtherFile, Converter={StaticResource BoolToVisibility}}">
                    <TextBlock Text="{Binding StatusMessage}" TextWrapping="Wrap" Foreground="#5A5A5A" />
                </Border>
            </Grid>
        </Grid>

        <TextBlock Grid.Row="2"
                   Text="{Binding StatusMessage}"
                   Foreground="#43546A"
                   TextTrimming="CharacterEllipsis" />
    </Grid>
</Window>
