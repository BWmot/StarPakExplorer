<Window x:Class="StarPakExplorer.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="clr-namespace:StarPakExplorer.UI"
        Title="StarPakExplorer - Starbound PAK 临时解包与检索器"
        Height="820"
        MinHeight="650"
        Width="1220"
        MinWidth="980"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />
    </Window.Resources>
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="6" />
            <RowDefinition Height="*" MinHeight="180" />
            <RowDefinition Height="6" />
            <RowDefinition Height="*" MinHeight="180" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Padding="12" Background="#F4F7FB" CornerRadius="8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal">
                    <Button Content="选择 asset_unpacker.exe" Command="{Binding SelectUnpackerCommand}" />
                    <Button Content="选择 PAK" Command="{Binding SelectPakCommand}" />
                    <Button Content="清理缓存" Command="{Binding ClearCacheCommand}" />
                </StackPanel>

                <TextBlock Grid.Row="0" Grid.Column="1"
                           Text="{Binding StatusMessage}"
                           VerticalAlignment="Center"
                           Foreground="#43546A"
                           TextTrimming="CharacterEllipsis" />

                <Grid Grid.Row="1" Grid.ColumnSpan="2" Margin="0,10,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Text="Unpacker:" FontWeight="SemiBold" Margin="0,0,8,4" />
                    <TextBlock Grid.Column="1" Text="{Binding AssetUnpackerPath}" TextTrimming="CharacterEllipsis" />
                    <TextBlock Grid.Row="1" Text="PAK:" FontWeight="SemiBold" Margin="0,0,8,0" />
                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding SelectedPakPath}" TextTrimming="CharacterEllipsis" />
                </Grid>
            </Grid>
        </Border>

        <Border Grid.Row="1" Margin="0,10,0,10" Padding="12" Background="#FFF7E8" CornerRadius="8">
            <DockPanel>
                <TextBlock Text="{Binding ModTitle}" FontSize="18" FontWeight="SemiBold" DockPanel.Dock="Left" />
                <TextBlock Text="{Binding MetadataSummary}"
                           Margin="18,4,0,0"
                           Foreground="#604B2B"
                           TextTrimming="CharacterEllipsis" />
            </DockPanel>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="540" />
                <ColumnDefinition Width="10" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <GroupBox Header="文件筛选">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="220" />
                    </Grid.ColumnDefinitions>

                    <TabControl Grid.Row="0"
                                Grid.ColumnSpan="2"
                                Margin="0,0,0,8"
                                ItemsSource="{Binding FileSections}"
                                SelectedItem="{Binding SelectedFileSection}">
                        <TabControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding DisplayName}" />
                                    <TextBlock Text=" (" />
                                    <TextBlock Text="{Binding Count}" />
                                    <TextBlock Text=")" />
                                </StackPanel>
                            </DataTemplate>
                        </TabControl.ItemTemplate>
                        <TabControl.ContentTemplate>
                            <DataTemplate>
                                <Border Height="0" />
                            </DataTemplate>
                        </TabControl.ContentTemplate>
                    </TabControl>

                    <ListBox Grid.Row="1"
                             Grid.Column="0"
                             ItemsSource="{Binding Files}"
                             SelectedItem="{Binding SelectedFile}"
                             DisplayMemberPath="DisplayPath"
                             FontFamily="Consolas"
                             FontSize="13">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Tag" Value="{Binding DataContext, RelativeSource={RelativeSource AncestorType=Window}}" />
                                <Setter Property="ContextMenu">
                                    <Setter.Value>
                                        <ContextMenu DataContext="{Binding PlacementTarget.Tag, RelativeSource={RelativeSource Self}}">
                                            <MenuItem Header="打开修改界面"
                                                      Command="{Binding OpenModifyWindowCommand}"
                                                      CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                        </ContextMenu>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                    </ListBox>

                    <Border Grid.Row="1"
                            Grid.Column="1"
                            Margin="8,0,0,0"
                            Padding="10"
                            Background="#FAFAFA"
                            BorderBrush="#E3E3E3"
                            BorderThickness="1"
                            CornerRadius="6">
                        <DockPanel>
                            <StackPanel DockPanel.Dock="Top" Margin="0,0,0,8">
                                <TextBlock Text="后缀勾选"
                                           FontWeight="SemiBold"
                                           Margin="0,0,0,6" />
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="全选" Width="64" Command="{Binding SelectAllExtensionsCommand}" />
                                    <Button Content="全不选" Width="76" Command="{Binding ClearExtensionSelectionCommand}" />
                                </StackPanel>
                            </StackPanel>

                            <ScrollViewer VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled">
                                <ItemsControl ItemsSource="{Binding ExtensionFilters}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <CheckBox IsChecked="{Binding IsChecked}">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="{Binding DisplayName}" />
                                                    <TextBlock Text=" (" />
                                                    <TextBlock Text="{Binding Count}" />
                                                    <TextBlock Text=")" />
                                                </StackPanel>
                                            </CheckBox>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </DockPanel>
                    </Border>
                </Grid>
            </GroupBox>

            <GridSplitter Grid.Column="1" Width="10" HorizontalAlignment="Stretch" />

            <GroupBox Grid.Column="2" Header="{Binding PreviewTitle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Margin="0,0,0,8"
                            Padding="10,6"
                            Background="#F7F7F7"
                            BorderBrush="#E3E3E3"
                            BorderThickness="1"
                            CornerRadius="6"
                            Visibility="{Binding PreviewModeSwitchVisible, Converter={StaticResource BoolToVisibility}}">
                        <DockPanel LastChildFill="True">
                            <TextBlock Text="{Binding PreviewModeHintText}"
                                       VerticalAlignment="Center"
                                       Foreground="#43546A"
                                       Margin="0,0,12,0" />

                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                <RadioButton Content="源数据"
                                             GroupName="PreviewMode"
                                             IsChecked="{Binding IsSourcePreviewMode, Mode=TwoWay}"
                                             Margin="0,0,8,0" />
                                <RadioButton Content="阅读模式"
                                             GroupName="PreviewMode"
                                             IsChecked="{Binding IsReadingPreviewMode, Mode=TwoWay}" />
                            </StackPanel>
                        </DockPanel>
                    </Border>

                    <Grid Grid.Row="1">
                        <StackPanel Visibility="{Binding IsImagePreviewVisible, Converter={StaticResource BoolToVisibility}}">
                            <Border Background="#F7F7F7" BorderBrush="#E3E3E3" BorderThickness="1" Padding="10" Margin="0,0,0,8" CornerRadius="6">
                                <DockPanel LastChildFill="True">
                                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                                        <Button Content="-" Width="34" Margin="0,0,6,0" Command="{Binding ZoomOutImageCommand}" />
                                        <Button Content="100%" Width="54" Margin="0,0,6,0" Command="{Binding ResetImageZoomCommand}" />
                                        <Button Content="+" Width="34" Margin="0,0,10,0" Command="{Binding ZoomInImageCommand}" />
                                    </StackPanel>

                                    <Slider Minimum="0.1"
                                            Maximum="8"
                                            Value="{Binding PreviewImageZoom, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                            TickFrequency="0.1"
                                            IsSnapToTickEnabled="False"
                                            VerticalAlignment="Center"
                                            Margin="0,0,10,0" />

                                    <TextBlock Text="{Binding PreviewImageInfoText}"
                                               VerticalAlignment="Center"
                                               HorizontalAlignment="Right"
                                               Foreground="#43546A" />
                                </DockPanel>
                            </Border>

                            <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                          VerticalScrollBarVisibility="Auto">
                                <Border Background="#F7F7F7" Padding="12">
                                    <Image Source="{Binding PreviewImageSource}"
                                           Width="{Binding PreviewImageWidth}"
                                           Height="{Binding PreviewImageHeight}"
                                           Stretch="None"
                                           RenderOptions.BitmapScalingMode="NearestNeighbor"
                                           SnapsToDevicePixels="True" />
                                </Border>
                            </ScrollViewer>
                        </StackPanel>

                        <TextBox Text="{Binding PreviewText}"
                                 FontFamily="Consolas"
                                 FontSize="13"
                                 AcceptsReturn="True"
                                 AcceptsTab="True"
                                 TextWrapping="NoWrap"
                                 VerticalScrollBarVisibility="Auto"
                                 HorizontalScrollBarVisibility="Auto"
                                 IsReadOnly="True"
                                 Visibility="{Binding IsSourcePreviewMode, Converter={StaticResource BoolToVisibility}}" />

                        <RichTextBox ui:RichTextBoxBindings.BoundDocument="{Binding PreviewDocument}"
                                     FontFamily="Consolas"
                                     FontSize="13"
                                     IsReadOnly="True"
                                     IsDocumentEnabled="True"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     VerticalScrollBarVisibility="Auto"
                                     HorizontalScrollBarVisibility="Auto"
                                     Visibility="{Binding IsReadingPreviewMode, Converter={StaticResource BoolToVisibility}}" />

                        <Border Background="#FAFAFA"
                                BorderBrush="#E3E3E3"
                                BorderThickness="1"
                                Padding="16"
                                CornerRadius="6"
                                Visibility="{Binding IsUnsupportedPreviewVisible, Converter={StaticResource BoolToVisibility}}">
                            <TextBlock Text="{Binding PreviewText}"
                                       FontFamily="Segoe UI"
                                       FontSize="14"
                                       TextWrapping="Wrap"
                                       Foreground="#5A5A5A" />
                        </Border>
                    </Grid>
                </Grid>
            </GroupBox>
        </Grid>

        <GridSplitter Grid.Row="3"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Stretch"
                      Background="#D0D7E2"
                      ShowsPreview="True"
                      ResizeDirection="Rows"
                      ResizeBehavior="PreviousAndNext" />

        <TabControl Grid.Row="4" Margin="0,10,0,0">
            <TabItem Header="关键词搜索">
                <DockPanel Margin="8">
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBox Width="360"
                                 Height="30"
                                 Text="{Binding SearchKeyword, UpdateSourceTrigger=PropertyChanged}"
                                 ToolTip="例如 extrachargebeam" />
                        <Button Content="搜索" Margin="8,0,8,0" Command="{Binding SearchCommand}" />
                        <TextBlock Text="{Binding SearchSummary}" VerticalAlignment="Center" Foreground="#43546A" />
                    </StackPanel>

                    <DataGrid ItemsSource="{Binding SearchHits}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="文件" Binding="{Binding FilePath}" Width="*" />
                            <DataGridTextColumn Header="行号" Binding="{Binding LineNumber}" Width="70" />
                            <DataGridTextColumn Header="命中内容" Binding="{Binding LineText}" Width="2*" />
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </TabItem>

            <TabItem Header="重复 itemName">
                <DockPanel Margin="8">
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,8">
                        <Button Content="扫描重复 itemName" Command="{Binding ScanDuplicateItemNamesCommand}" />
                        <TextBlock Text="{Binding DuplicateSummary}" VerticalAlignment="Center" Foreground="#43546A" />
                    </StackPanel>

                    <DataGrid ItemsSource="{Binding DuplicateItemNames}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="itemName" Binding="{Binding ItemName}" Width="240" />
                            <DataGridTextColumn Header="次数" Binding="{Binding Count}" Width="70" />
                            <DataGridTextColumn Header="命中文件与行号" Binding="{Binding HitSummary}" Width="*" />
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </TabItem>
        </TabControl>

        <GridSplitter Grid.Row="5"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Stretch"
                      Background="#D0D7E2"
                      ShowsPreview="True"
                      ResizeDirection="Rows"
                      ResizeBehavior="PreviousAndNext" />

        <GroupBox Grid.Row="6" Header="缓存概览" Margin="0,10,0,0" MinHeight="180">
            <Grid Margin="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="220" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Padding="10"
                        Background="#FAFAFA"
                        BorderBrush="#E3E3E3"
                        BorderThickness="1"
                        CornerRadius="6">
                    <StackPanel>
                        <TextBlock Text="{Binding CacheSummaryText}"
                                   FontWeight="SemiBold"
                                   FontSize="14"
                                   Margin="0,0,0,8" />
                        <StackPanel Orientation="Horizontal">
                            <Button Content="刷新"
                                    Width="68"
                                    Margin="0,0,6,0"
                                    Command="{Binding RefreshCacheOverviewCommand}" />
                            <Button Content="全选"
                                    Width="68"
                                    Margin="0,0,6,0"
                                    Command="{Binding SelectAllCacheEntriesCommand}" />
                            <Button Content="取消"
                                    Width="68"
                                    Margin="0,0,6,0"
                                    Command="{Binding ClearCacheSelectionCommand}" />
                            <Button Content="删除选中"
                                    Width="86"
                                    Command="{Binding DeleteSelectedCacheCommand}" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2"
                        Padding="10"
                        Background="#FAFAFA"
                        BorderBrush="#E3E3E3"
                        BorderThickness="1"
                        CornerRadius="6">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding RecentCacheEntries}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="8"
                                            Margin="0,0,0,8"
                                            Background="White"
                                            BorderBrush="#E8E8E8"
                                            BorderThickness="1"
                                            CornerRadius="5">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="8" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <CheckBox Grid.Column="0"
                                                      VerticalAlignment="Center"
                                                      IsChecked="{Binding IsSelected}" />
                                            <StackPanel Grid.Column="2">
                                                <TextBlock Text="{Binding Title}"
                                                           FontWeight="SemiBold"
                                                           TextTrimming="CharacterEllipsis" />
                                                <TextBlock Text="{Binding Subtitle}"
                                                           Foreground="#667"
                                                           TextTrimming="CharacterEllipsis" />
                                                <TextBlock Text="{Binding Detail}"
                                                           Foreground="#667"
                                                           FontSize="12" />
                                            </StackPanel>
                                            <Button Grid.Column="3"
                                                    Content="重载"
                                                    Margin="12,0,0,0"
                                                    VerticalAlignment="Center"
                                                    Command="{Binding OpenCommand}" />
                                            <Button Grid.Column="4"
                                                    Content="删除"
                                                    Margin="8,0,0,0"
                                                    VerticalAlignment="Center"
                                                    Foreground="#B00020"
                                                    Command="{Binding DeleteCommand}" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>
            </Grid>
        </GroupBox>

        <ProgressBar Grid.Row="7"
                     Height="4"
                     Margin="0,10,0,0"
                     IsIndeterminate="{Binding IsBusy}" />
    </Grid>
</Window>
