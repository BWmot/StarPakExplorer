<Window x:Class="StarPakExplorer.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="StarPakExplorer - Starbound PAK 临时解包与检索器"
        Height="820"
        MinHeight="650"
        Width="1220"
        MinWidth="980"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />
    </Window.Resources>
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="240" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Padding="12" Background="#F4F7FB" CornerRadius="8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal">
                    <Button Content="选择 asset_unpacker.exe" Command="{Binding SelectUnpackerCommand}" />
                    <Button Content="选择 PAK" Command="{Binding SelectPakCommand}" />
                    <Button Content="清理缓存" Command="{Binding ClearCacheCommand}" />
                </StackPanel>

                <TextBlock Grid.Row="0" Grid.Column="1"
                           Text="{Binding StatusMessage}"
                           VerticalAlignment="Center"
                           Foreground="#43546A"
                           TextTrimming="CharacterEllipsis" />

                <Grid Grid.Row="1" Grid.ColumnSpan="2" Margin="0,10,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Text="Unpacker:" FontWeight="SemiBold" Margin="0,0,8,4" />
                    <TextBlock Grid.Column="1" Text="{Binding AssetUnpackerPath}" TextTrimming="CharacterEllipsis" />
                    <TextBlock Grid.Row="1" Text="PAK:" FontWeight="SemiBold" Margin="0,0,8,0" />
                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding SelectedPakPath}" TextTrimming="CharacterEllipsis" />
                </Grid>
            </Grid>
        </Border>

        <Border Grid.Row="1" Margin="0,10,0,10" Padding="12" Background="#FFF7E8" CornerRadius="8">
            <DockPanel>
                <TextBlock Text="{Binding ModTitle}" FontSize="18" FontWeight="SemiBold" DockPanel.Dock="Left" />
                <TextBlock Text="{Binding MetadataSummary}"
                           Margin="18,4,0,0"
                           Foreground="#604B2B"
                           TextTrimming="CharacterEllipsis" />
            </DockPanel>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="540" />
                <ColumnDefinition Width="10" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <GroupBox Header="文件筛选">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="220" />
                    </Grid.ColumnDefinitions>

                    <TabControl Grid.Row="0"
                                Grid.ColumnSpan="2"
                                Margin="0,0,0,8"
                                ItemsSource="{Binding FileSections}"
                                SelectedItem="{Binding SelectedFileSection}">
                        <TabControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding DisplayName}" />
                                    <TextBlock Text=" (" />
                                    <TextBlock Text="{Binding Count}" />
                                    <TextBlock Text=")" />
                                </StackPanel>
                            </DataTemplate>
                        </TabControl.ItemTemplate>
                        <TabControl.ContentTemplate>
                            <DataTemplate>
                                <Border Height="0" />
                            </DataTemplate>
                        </TabControl.ContentTemplate>
                    </TabControl>

                    <ListBox Grid.Row="1"
                             Grid.Column="0"
                             ItemsSource="{Binding Files}"
                             SelectedItem="{Binding SelectedFile}"
                             DisplayMemberPath="DisplayPath"
                             FontFamily="Consolas"
                             FontSize="13" />

                    <Border Grid.Row="1"
                            Grid.Column="1"
                            Margin="8,0,0,0"
                            Padding="10"
                            Background="#FAFAFA"
                            BorderBrush="#E3E3E3"
                            BorderThickness="1"
                            CornerRadius="6">
                        <DockPanel>
                            <StackPanel DockPanel.Dock="Top" Margin="0,0,0,8">
                                <TextBlock Text="后缀勾选"
                                           FontWeight="SemiBold"
                                           Margin="0,0,0,6" />
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="全选" Width="64" Command="{Binding SelectAllExtensionsCommand}" />
                                    <Button Content="全不选" Width="76" Command="{Binding ClearExtensionSelectionCommand}" />
                                </StackPanel>
                            </StackPanel>

                            <ScrollViewer VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled">
                                <ItemsControl ItemsSource="{Binding ExtensionFilters}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <CheckBox IsChecked="{Binding IsChecked}">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="{Binding DisplayName}" />
                                                    <TextBlock Text=" (" />
                                                    <TextBlock Text="{Binding Count}" />
                                                    <TextBlock Text=")" />
                                                </StackPanel>
                                            </CheckBox>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </DockPanel>
                    </Border>
                </Grid>
            </GroupBox>

            <GridSplitter Grid.Column="1" Width="10" HorizontalAlignment="Stretch" />

            <GroupBox Grid.Column="2" Header="{Binding PreviewTitle}">
                <Grid>
                    <StackPanel Visibility="{Binding IsImagePreviewVisible, Converter={StaticResource BoolToVisibility}}">
                        <Border Background="#F7F7F7" BorderBrush="#E3E3E3" BorderThickness="1" Padding="10" Margin="0,0,0,8" CornerRadius="6">
                            <DockPanel LastChildFill="True">
                                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                                    <Button Content="-" Width="34" Margin="0,0,6,0" Command="{Binding ZoomOutImageCommand}" />
                                    <Button Content="100%" Width="54" Margin="0,0,6,0" Command="{Binding ResetImageZoomCommand}" />
                                    <Button Content="+" Width="34" Margin="0,0,10,0" Command="{Binding ZoomInImageCommand}" />
                                </StackPanel>

                                <Slider Minimum="0.1"
                                        Maximum="8"
                                        Value="{Binding PreviewImageZoom, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                        TickFrequency="0.1"
                                        IsSnapToTickEnabled="False"
                                        VerticalAlignment="Center"
                                        Margin="0,0,10,0" />

                                <TextBlock Text="{Binding PreviewImageInfoText}"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Right"
                                           Foreground="#43546A" />
                            </DockPanel>
                        </Border>

                        <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                      VerticalScrollBarVisibility="Auto">
                            <Border Background="#F7F7F7" Padding="12">
                                <Image Source="{Binding PreviewImageSource}"
                                       Width="{Binding PreviewImageWidth}"
                                       Height="{Binding PreviewImageHeight}"
                                       Stretch="None"
                                       RenderOptions.BitmapScalingMode="NearestNeighbor"
                                       SnapsToDevicePixels="True" />
                            </Border>
                        </ScrollViewer>
                    </StackPanel>

                    <TextBox Text="{Binding PreviewText}"
                             FontFamily="Consolas"
                             FontSize="13"
                             AcceptsReturn="True"
                             AcceptsTab="True"
                             TextWrapping="NoWrap"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto"
                             IsReadOnly="True"
                             Visibility="{Binding IsTextPreviewVisible, Converter={StaticResource BoolToVisibility}}" />

                    <Border Background="#FAFAFA"
                            BorderBrush="#E3E3E3"
                            BorderThickness="1"
                            Padding="16"
                            CornerRadius="6"
                            Visibility="{Binding IsUnsupportedPreviewVisible, Converter={StaticResource BoolToVisibility}}">
                        <TextBlock Text="{Binding PreviewText}"
                                   FontFamily="Segoe UI"
                                   FontSize="14"
                                   TextWrapping="Wrap"
                                   Foreground="#5A5A5A" />
                    </Border>
                </Grid>
            </GroupBox>
        </Grid>

        <TabControl Grid.Row="3" Margin="0,10,0,0">
            <TabItem Header="关键词搜索">
                <DockPanel Margin="8">
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBox Width="360"
                                 Height="30"
                                 Text="{Binding SearchKeyword, UpdateSourceTrigger=PropertyChanged}"
                                 ToolTip="例如 extrachargebeam" />
                        <Button Content="搜索" Margin="8,0,8,0" Command="{Binding SearchCommand}" />
                        <TextBlock Text="{Binding SearchSummary}" VerticalAlignment="Center" Foreground="#43546A" />
                    </StackPanel>

                    <DataGrid ItemsSource="{Binding SearchHits}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="文件" Binding="{Binding FilePath}" Width="*" />
                            <DataGridTextColumn Header="行号" Binding="{Binding LineNumber}" Width="70" />
                            <DataGridTextColumn Header="命中内容" Binding="{Binding LineText}" Width="2*" />
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </TabItem>

            <TabItem Header="重复 itemName">
                <DockPanel Margin="8">
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,8">
                        <Button Content="扫描重复 itemName" Command="{Binding ScanDuplicateItemNamesCommand}" />
                        <TextBlock Text="{Binding DuplicateSummary}" VerticalAlignment="Center" Foreground="#43546A" />
                    </StackPanel>

                    <DataGrid ItemsSource="{Binding DuplicateItemNames}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="itemName" Binding="{Binding ItemName}" Width="240" />
                            <DataGridTextColumn Header="次数" Binding="{Binding Count}" Width="70" />
                            <DataGridTextColumn Header="命中文件与行号" Binding="{Binding HitSummary}" Width="*" />
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </TabItem>
        </TabControl>

        <ProgressBar Grid.Row="4"
                     Height="4"
                     Margin="0,10,0,0"
                     IsIndeterminate="{Binding IsBusy}" />
    </Grid>
</Window>
