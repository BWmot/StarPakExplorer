<Window x:Class="StarPakExplorer.UI.PatchManagerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="补丁管理"
        Width="1100"
        Height="720"
        MinWidth="960"
        MinHeight="620"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Padding="12"
                Background="#F4F7FB"
                CornerRadius="8">
            <DockPanel LastChildFill="True">
                <StackPanel DockPanel.Dock="Left">
                    <TextBlock Text="{Binding PatchRoot}" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding SelectedPatchSummary}" Foreground="#43546A" />
                </StackPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button Content="刷新" Command="{Binding RefreshCommand}" />
                    <Button Content="打开目录" Command="{Binding OpenRootCommand}" />
                    <Button Content="删除补丁集" Command="{Binding DeleteSelectedSetCommand}" />
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Row="1" Margin="0,12,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Padding="10"
                    Background="#FAFAFA"
                    BorderBrush="#E3E3E3"
                    BorderThickness="1"
                    CornerRadius="6">
                <ListBox ItemsSource="{Binding PatchSets}"
                         SelectedItem="{Binding SelectedPatchSet}"
                         DisplayMemberPath="DisplayName"
                         FontFamily="Consolas"
                         FontSize="13" />
            </Border>

            <Border Grid.Column="2"
                    Padding="10"
                    Background="#FAFAFA"
                    BorderBrush="#E3E3E3"
                    BorderThickness="1"
                    CornerRadius="6">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,8">
                        <Button Content="删除选中文件" Command="{Binding DeleteSelectedFilesCommand}" />
                    </StackPanel>

                    <DataGrid ItemsSource="{Binding Files}">
                        <DataGrid.Columns>
                            <DataGridCheckBoxColumn Header="选中" Binding="{Binding IsSelected}" Width="60" />
                            <DataGridTextColumn Header="文件路径" Binding="{Binding DisplayPath}" Width="2*" />
                            <DataGridTextColumn Header="信息" Binding="{Binding Detail}" Width="*" />
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </Border>
        </Grid>

        <TextBlock Grid.Row="2"
                   Text="{Binding StatusMessage}"
                   Foreground="#43546A"
                   TextTrimming="CharacterEllipsis" />
    </Grid>
</Window>
