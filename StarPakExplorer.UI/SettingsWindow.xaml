<Window x:Class="StarPakExplorer.UI.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings"
        Width="760"
        Height="520"
        MinWidth="700"
        MinHeight="380"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Padding="14"
                Background="#F4F7FB"
                CornerRadius="8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="180" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Text="asset_unpacker.exe"
                           VerticalAlignment="Center"
                           FontWeight="SemiBold" />
                <TextBox Grid.Column="1"
                         Text="{Binding AssetUnpackerPath, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,8,8" />
                <Button Grid.Column="2"
                        Content="Browse..."
                        Command="{Binding BrowseUnpackerCommand}" />

                <TextBlock Grid.Row="1"
                           Text="Default PAK folder"
                           VerticalAlignment="Center"
                           FontWeight="SemiBold" />
                <TextBox Grid.Row="1"
                         Grid.Column="1"
                         Text="{Binding PakParentDirectory, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,8,8" />
                <Button Grid.Row="1"
                        Grid.Column="2"
                        Content="Browse..."
                        Command="{Binding BrowsePakDirectoryCommand}" />

                <TextBlock Grid.Row="2"
                           Text="asset_packer.exe"
                           VerticalAlignment="Center"
                           FontWeight="SemiBold" />
                <TextBox Grid.Row="2"
                         Grid.Column="1"
                         Text="{Binding AssetPackerPath, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,8,8" />
                <Button Grid.Row="2"
                        Grid.Column="2"
                        Content="Browse..."
                        Command="{Binding BrowsePackerCommand}" />

                <TextBlock Grid.Row="3"
                           Text="Patch folder"
                           VerticalAlignment="Center"
                           FontWeight="SemiBold" />
                <TextBox Grid.Row="3"
                         Grid.Column="1"
                         Text="{Binding PatchRootDirectory, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,8,8" />
                <Button Grid.Row="3"
                        Grid.Column="2"
                        Content="Browse..."
                        Command="{Binding BrowsePatchRootCommand}" />

                <TextBlock Grid.Row="4"
                           Text="Cache folder"
                           VerticalAlignment="Center"
                           FontWeight="SemiBold" />
                <TextBox Grid.Row="4"
                         Grid.Column="1"
                         Text="{Binding CacheRootDirectory, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,8,8" />
                <Button Grid.Row="4"
                        Grid.Column="2"
                        Content="Browse..."
                        Command="{Binding BrowseCacheRootCommand}" />

                <TextBlock Grid.Row="5"
                           Grid.ColumnSpan="3"
                           Text="Leave blank to use the default LocalAppData folder."
                           Foreground="#667"
                           Margin="0,8,0,0" />
            </Grid>
        </Border>

        <DockPanel Grid.Row="1" Margin="0,12,0,0">
            <TextBlock Text="{Binding StatusMessage}"
                       VerticalAlignment="Center"
                       Foreground="#43546A"
                       DockPanel.Dock="Left" />
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Cancel" Width="88" Command="{Binding CancelCommand}" />
                <Button Content="Save" Width="88" Command="{Binding SaveCommand}" />
            </StackPanel>
        </DockPanel>
    </Grid>
</Window>
