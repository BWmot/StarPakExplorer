<Window x:Class="StarPakExplorer.UI.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="设置"
        Width="760"
        Height="360"
        MinWidth="700"
        MinHeight="320"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Padding="14"
                Background="#F4F7FB"
                CornerRadius="8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="180" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Text="asset_unpacker.exe"
                           VerticalAlignment="Center"
                           FontWeight="SemiBold" />
                <TextBox Grid.Column="1"
                         Text="{Binding AssetUnpackerPath, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,8,8" />
                <Button Grid.Column="2"
                        Content="浏览..."
                        Command="{Binding BrowseUnpackerCommand}" />

                <TextBlock Grid.Row="1"
                           Text="PAK 默认目录"
                           VerticalAlignment="Center"
                           FontWeight="SemiBold" />
                <TextBox Grid.Row="1"
                         Grid.Column="1"
                         Text="{Binding PakParentDirectory, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,8,8" />
                <Button Grid.Row="1"
                        Grid.Column="2"
                        Content="浏览..."
                        Command="{Binding BrowsePakDirectoryCommand}" />

                <TextBlock Grid.Row="2"
                           Text="补丁目录"
                           VerticalAlignment="Center"
                           FontWeight="SemiBold" />
                <TextBox Grid.Row="2"
                         Grid.Column="1"
                         Text="{Binding PatchRootDirectory, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,8,8" />
                <Button Grid.Row="2"
                        Grid.Column="2"
                        Content="浏览..."
                        Command="{Binding BrowsePatchRootCommand}" />

                <TextBlock Grid.Row="3"
                           Grid.ColumnSpan="3"
                           Text="留空时会使用默认的本地应用数据目录。"
                           Foreground="#667"
                           Margin="0,8,0,0" />
            </Grid>
        </Border>

        <DockPanel Grid.Row="1" Margin="0,12,0,0">
            <TextBlock Text="{Binding StatusMessage}"
                       VerticalAlignment="Center"
                       Foreground="#43546A"
                       DockPanel.Dock="Left" />
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="取消" Width="88" Command="{Binding CancelCommand}" />
                <Button Content="保存" Width="88" Command="{Binding SaveCommand}" />
            </StackPanel>
        </DockPanel>
    </Grid>
</Window>
